# Copy this file to .env for local development.
# .env is ignored by git. Do not commit real API keys.

# Server
CONTEXT_GENOME_HOST=127.0.0.1
CONTEXT_GENOME_PORT=8765

# OpenAI-compatible LLM runtime
CONTEXT_GENOME_LLM_API_KEY=
CONTEXT_GENOME_LLM_MODEL=deepseek-v4-flash
CONTEXT_GENOME_LLM_BASE_URL=https://api.deepseek.com/v1
CONTEXT_GENOME_LLM_JSON_MODE=1
CONTEXT_GENOME_LLM_DISABLE_THINKING=1
